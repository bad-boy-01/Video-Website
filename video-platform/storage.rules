rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Default rule: reject all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /videos/{videoId}/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /thumbnails/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}